# Neon Postgres — pooled connection string (…-pooler.…neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Shared login password for the app UI
APP_PASSWORD="change-me"

# Bearer token for POST /api/staged (external OCR pipeline)
INGEST_TOKEN="change-me-too"

# Optional: separate secret for signing session cookies (defaults to APP_PASSWORD)
# SESSION_SECRET=""
